# --- API KEYS ---


# Get yours at https://aistudio.google.com/
EMBEDDING_MODEL_API_KEY=your_gemini_api_key_here
EMBEDDING_MODEL=models/text-embedding-001

# Get yours at https://console.groq.com/
GEN_AI_URL = your_gen_ai_url_here
GEN_AI_API_KEY=your_groq_api_key_here

# Get yours at https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here

# --- PINECONE CONFIG ---
# The Host URL found in your Pinecone project dashboard
PINECONE_HOST=https://your-index-name-xyz.svc.vectordb.pinecone.io

# The name of your index (e.g., plumbing-knowledge)
PINECONE_INDEX_NAME=plumbing-knowledge

# --- MODEL CONFIG ---
# Dimension for gemini-embedding-001 (Default is 768 or 3072)
EMBEDDING_DIMENSION=768